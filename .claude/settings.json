{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": {
          "tools": ["Read", "Edit", "Write"]
        },
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-secrets.py"
          }
        ]
      },
      {
        "matcher": {
          "tools": ["Edit", "Write"]
        },
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-protected-files.sh"
          }
        ]
      },
      {
        "matcher": {
          "tools": ["Bash"]
        },
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous-commands.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": []
  }
}
